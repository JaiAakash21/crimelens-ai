# CrimeLens AI — Environment Configuration
# Copy this file to .env and fill in your values

# FastAPI
DEBUG=false
APP_NAME=CrimeLens AI
# APP_VERSION=1.0.0

# Supabase
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# OSRM (optional — defaults to public demo server)
# In production, use a self-hosted OSRM instance to avoid rate limits
OSRM_BASE_URL=https://router.project-osrm.org

# CORS — restrict to your dashboard domain in production
# Example: CORS_ORIGINS=["https://dashboard.crimelens.ai"]
# WARNING: ["*"] allows any website to call the API
# CORS_ORIGINS=["http://localhost:3000"]

# Storage
STORAGE_BUCKET=incident-images
MAX_IMAGE_SIZE_MB=5
# ALLOWED_IMAGE_TYPES=["image/jpeg","image/png","image/webp"]

# Hotspot Detection
HOTSPOT_MIN_SAMPLES=3
HOTSPOT_EPS_METERS=300.0
HOTSPOT_INCIDENT_DAYS=90

# Risk Scoring
RISK_SCORE_TTL_MINUTES=60
# RISK_GRID_RESOLUTION=9

# JWT validation (optional — fallback for supabase.auth.get_user())
# Find this in: Supabase Dashboard → Project Settings → API → JWT Settings
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here
